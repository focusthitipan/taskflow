# ── Database (PostgreSQL) ──
# Prisma connection string for PostgreSQL
DATABASE_URL="postgresql://user:password@localhost:5432/taskflow?schema=public"

# ── NextAuth.js ──
# Base URL of the application (required in production)
NEXTAUTH_URL="http://localhost:3000"
# Secret key for JWT signing (generate with: openssl rand -base64 32)
NEXTAUTH_SECRET="change-me-to-a-random-secret"
